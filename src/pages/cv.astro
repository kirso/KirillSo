---
import BaseLayout from "@/layouts/Base.astro";
import Schema from "@/components/Schema.astro";

const meta = {
  title: "CV",
  description: "Kirill So — product manager, builder, and occasional writer. Career history and skills.",
};

interface Role {
  title: string;
  company: string;
  companyUrl?: string;
  location: string;
  period: string;
  highlights: string[];
}

const experience: Role[] = [
  {
    title: "Founder",
    company: "Epigraf",
    period: "2025 — Present",
    location: "Remote",
    highlights: [
      "Building human-centric products with AI-powered development workflows",
      "Keepsake — preserve family memories. Accepted to Iterative validation sprint with $10k grant, collected 100 beta sign-ups pre-launch. Using LLMs for transcoding and transcription of video and audio",
      "CitizenTrail — one-stop shop for immigration data. Orchestrating scraping pipelines with LLMs for data extraction and schema normalization from public government sources",
    ],
  },
  {
    title: "Principal Product Manager (M2 / IC5)",
    company: "Delivery Hero",
    companyUrl: "https://www.deliveryhero.com/",
    period: "2022 — 2025",
    location: "Berlin / Remote",
    highlights: [
      "Shipped a 0-to-1 API gateway infrastructure product that orchestrates incentive-related data and drives platform profitability across 21 markets in Europe and APAC",
      "Shaped and executed a product roadmap for 2 teams of 20 engineers",
      "Centralized architecture that resolved UX inconsistencies in 21 countries, affecting 50m+ users and saving 50 hours/month in engineering capacity",
      "Launched a high-value actions initiative to lift acquisition, reactivation, and subscription metrics, on track to generate $100m/year in incremental GMV",
      "Built a new incentive component that produced $16.5m in GMV uplift",
    ],
  },
  {
    title: "Product Manager, Growth",
    company: "Standard Chartered, Ventures",
    period: "2020 — 2022",
    location: "Singapore",
    highlights: [
      "Grew a consumer-facing mobile app to 100k MAU in 12 months via 3rd party integrations, SDKs, partnerships & cross-sell channels",
    ],
  },
  {
    title: "Entrepreneur",
    company: "Antler",
    companyUrl: "https://www.antler.co/",
    period: "2019 — 2020",
    location: "Singapore",
    highlights: [
      "Took part in a venture studio program and disproved the hypothesis that aimed to improve the efficacy of deploying machine learning models in production",
    ],
  },
  {
    title: "Product & Venture Lead",
    company: "Carousell",
    companyUrl: "https://www.carousell.com/",
    period: "2018 — 2019",
    location: "Singapore",
    highlights: [
      "Collaborated with founders on a decentralized identity platform aimed at fraud prevention",
      "Built the MVP, secured 30+ data partnerships",
    ],
  },
  {
    title: "Director, Business Development",
    company: "Remerge",
    companyUrl: "https://www.remerge.io/",
    period: "2015 — 2018",
    location: "Berlin",
    highlights: [
      "Delivered over $50m in advertising budgets",
      "Closed strategic accounts while working closely with cross-functional teams and leadership",
    ],
  },
  {
    title: "Business Development Manager",
    company: "IONIQ Group",
    companyUrl: "https://www.ioniq.com/",
    period: "2012 — 2015",
    location: "Berlin",
    highlights: [
      "Acquired and managed a sales pipeline of $1m+",
      "Worked with game publishers, advertising networks, entertainment and media outlets, and TV stations",
    ],
  },
  {
    title: "Analyst, Private Equity",
    company: "EnerCap Capital Partners",
    companyUrl: "https://www.enercap.com/",
    period: "2010 — 2012",
    location: "Prague",
    highlights: [
      "Supported partners in raising $450m+ debt financing for renewable energy projects",
      "Projects provided electricity to 200,000 households and saved 130,000 tonnes of CO2 p.a.",
    ],
  },
];

interface SkillGroup {
  label: string;
  items: string[];
}

const skills: SkillGroup[] = [
  { label: "Fundamentals", items: ["HTML", "CSS", "JavaScript", "TypeScript", "SQL"] },
  { label: "Frameworks", items: ["Svelte", "SvelteKit", "Astro"] },
  { label: "Design", items: ["Figma", "Procreate", "Webflow", "Framer"] },
  { label: "Analytics", items: ["Google Analytics", "Adjust", "AppsFlyer"] },
  { label: "Other", items: ["Facebook Ads", "Google Ads", "Apple Search Ads", "SEO", "ASO"] },
];

const projects = [
  { name: "Keepsake", description: "Preserve your family memories", tech: "Svelte, SvelteKit, Neon, Cloudflare, Print API" },
  { name: "SchwiftyVerse", description: "Save GIFs on a blockchain", tech: "React, Solana" },
  { name: "Panic theme", description: "Make Logseq pretty", tech: "CSS" },
  { name: "The Early Adopter", description: "Discover digital products", tech: "" },
];

interface Education {
  degree: string;
  school: string;
  period: string;
}

const education: Education[] = [
  {
    degree: "Bachelor's in Communications & Media Studies",
    school: "Jan Amos Komensky University",
    period: "2007 — 2010",
  },
];

interface OtherEducation {
  program: string;
  school: string;
}

const otherEducation: OtherEducation[] = [
  { program: "Mastering Product Management", school: "Reforge" },
  { program: "Experimentation & Testing", school: "Reforge" },
  { program: "Finding Product-Market Fit", school: "Reforge" },
  { program: "Software Engineering", school: "Launch School" },
  { program: "Cybersecurity", school: "TryHackMe" },
  { program: "Public Speaking", school: "Ultraspeaking" },
];
---

<BaseLayout meta={meta}>
  <Schema type="breadcrumb" breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "CV", url: "/cv/" }
  ]} />
  <article>
    <header class="mb-16">
      <h1 class="page-title">Kirill So</h1>
      <p class="mt-2 text-text-secondary">Product Manager & Builder</p>
      <p class="mt-4 max-w-2xl text-text-secondary leading-relaxed" style="font-size: var(--text-micro);">
        Hands-on product manager with 14 years of experience in B2C & B2B, from seed-stage startups to post-IPO organizations in adtech, fintech, marketplaces, private equity, & renewable energy. In my free time, I build products, always learning & cultivating a beginner's mind.
      </p>
      <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-text-tertiary" style="font-size: var(--text-micro);">
        <a class="link-muted" href="mailto:kirill.sofronov@gmail.com">kirill.sofronov@gmail.com</a>
        <span>/</span>
        <a class="link-muted" href="https://www.kirillso.com">kirillso.com</a>
        <span>/</span>
        <a class="link-muted" href="https://www.linkedin.com/in/kirso" target="_blank" rel="noopener">LinkedIn</a>
        <span>/</span>
        <a class="link-muted" href="https://github.com/kirso" target="_blank" rel="noopener">GitHub</a>
      </div>
    </header>

    <!-- Experience -->
    <section class="mb-16">
      <div class="section-rule"><span>Experience</span></div>
      <div class="space-y-8">
        {experience.map((role) => (
          <div>
            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <div>
                <h3 class="font-medium">{role.title}</h3>
                <p class="text-text-secondary" style="font-size: var(--text-micro);">
                  {role.companyUrl ? (
                    <a class="link-muted" href={role.companyUrl} target="_blank" rel="noopener">{role.company}</a>
                  ) : (
                    role.company
                  )}
                  <span class="text-text-tertiary"> · {role.location}</span>
                </p>
              </div>
              <span class="mono text-text-tertiary shrink-0" style="font-size: var(--text-micro);">{role.period}</span>
            </div>
            <ul class="chevron-list mt-2 text-text-secondary" style="font-size: var(--text-micro);">
              {role.highlights.map((h) => <li>{h}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Tech / Skills -->
    <section class="mb-16">
      <div class="section-rule"><span>Tech</span></div>
      <div class="grid gap-6 sm:grid-cols-2">
        {skills.map((group) => (
          <div>
            <p class="text-text-tertiary mb-2" style="font-size: var(--text-micro);">{group.label}</p>
            <div class="flex flex-wrap gap-2">
              {group.items.map((s) => <span class="tag">{s}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Projects -->
    <section class="mb-16">
      <div class="section-rule"><span>Projects</span></div>
      <ul class="space-y-3">
        {projects.map((p) => (
          <li>
            <div class="flex flex-col gap-0.5">
              <span class="font-medium">{p.name} <span class="text-text-secondary font-normal">— {p.description}</span></span>
              {p.tech && (
                <span class="text-text-tertiary" style="font-size: var(--text-micro);">{p.tech}</span>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Education -->
    <section class="mb-16">
      <div class="section-rule"><span>Education</span></div>
      <div class="space-y-4">
        {education.map((edu) => (
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <div>
              <h3 class="font-medium">{edu.degree}</h3>
              <p class="text-text-secondary" style="font-size: var(--text-micro);">{edu.school}</p>
            </div>
            <span class="mono text-text-tertiary shrink-0" style="font-size: var(--text-micro);">{edu.period}</span>
          </div>
        ))}
      </div>

      {/* Other education / courses */}
      <div class="mt-8">
        <p class="text-text-tertiary mb-3" style="font-size: var(--text-micro);">Courses & Programs</p>
        <div class="grid gap-2 sm:grid-cols-2">
          {otherEducation.map((item) => (
            <div class="flex items-baseline justify-between gap-4" style="font-size: var(--text-micro);">
              <span class="text-text-secondary">{item.program}</span>
              <span class="text-text-tertiary shrink-0">{item.school}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Download -->
    <nav class="mt-12">
      <a
        class="arrow-link"
        href="https://www.kirillso.com/resume.pdf"
        download="Kirill-So-CV.pdf"
      >Download as PDF <span aria-hidden="true">→</span></a>
    </nav>
  </article>
</BaseLayout>
