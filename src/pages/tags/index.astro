---
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import Schema from "@/components/Schema.astro";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);
const totalPosts = allPosts.length;

// Sort by count descending
const sortedTags = [...allTags].sort((a, b) => b[1] - a[1]);

const meta = {
	description:
		"A full index of topics and themes I've written about on life, technology, business, learning, thinking, and more",
	title: "Tags",
};
---

<PageLayout meta={meta}>
  <Schema type="breadcrumb" breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Tags", url: "/tags/" }
  ]} />
  <header class="mb-12">
    <h1 class="page-title">Tags</h1>
    <p class="mt-2 text-text-secondary">All topics I write about, sorted by frequency. {allTags.length} topics across {totalPosts} posts.</p>
  </header>

  <section>
    <div class="section-rule mb-6"><span>All Topics</span></div>
    <div class="flex flex-wrap gap-3">
      {
        sortedTags.map(([tag, count]) => (
          <a
            class="tag inline-flex items-center gap-1.5"
            href={`/tags/${tag}/`}
          >
            #{tag}
            <span class="text-text-tertiary" style="font-size: 10px;">{count}</span>
          </a>
        ))
      }
    </div>
  </section>

  <nav class="mt-12">
    <a class="arrow-link" href="/posts/">
      View all posts <span aria-hidden="true">→</span>
    </a>
  </nav>
</PageLayout>
