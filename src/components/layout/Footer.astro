---
import { menuLinks, siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<!-- End mark — consistent page termination -->
<div class="end-mark"></div>

<footer
  class="mt-8 border-t border-border pt-8 pb-4 text-text-secondary"
  style="font-size: var(--text-micro);"
>
  <div class="mb-4 flex items-center justify-between">
    <p class="text-text-tertiary">Thoughts on building, products, and life.</p>
    <a
      class="arrow-link shrink-0"
      href="https://kirill.substack.com"
      target="_blank"
      rel="noopener"
    >Subscribe <span aria-hidden="true">→</span></a>
  </div>
  <div class="flex flex-col items-center justify-center gap-y-2 text-center sm:flex-row sm:justify-between">
    <div class="me-0 sm:me-4">
      {siteConfig.author} &copy; {year}
    </div>
    <nav
      aria-labelledby="footer_links"
      class="flex flex-wrap justify-center gap-x-4"
    >
      <p id="footer_links" class="sr-only">More on this site</p>
      {
        menuLinks.map((link) => (
          <a
            class="link-muted"
            href={link.path}
          >
            {link.title}
          </a>
        ))
      }
      <a class="link-muted" href="/tags/">Tags</a>
      <a class="link-muted" href="/rss.xml">RSS</a>
      <a class="link-muted" href="/privacy/">Privacy</a>
    </nav>
  </div>
</footer>
