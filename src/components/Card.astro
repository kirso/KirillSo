---
/**
 * Card — Consistent with design system
 * Use inside a bordered container with divide-y for connected look.
 * Hover: inverts colors (bg-global-text, text-global-bg).
 * Description uses /80 opacity for hierarchy in inverted state.
 */
export type Props = {
	to: string;
	title: string;
	description: string;
	status?: "active" | "archived";
};

const { title, description, to, status } = Astro.props;
const isExternal = to?.startsWith("http") ?? false;
---

<a
	class="group block p-4 transition-colors hover:bg-global-text hover:text-global-bg"
	href={to}
	target={isExternal ? "_blank" : undefined}
	rel={isExternal ? "noopener noreferrer" : undefined}
>
	<div class="flex items-start justify-between gap-4">
		<div>
			<div class="flex items-center gap-2">
				<span class="font-medium">{title}</span>
				{status && (
					<span
						class:list={[
							"inline-block border px-1.5 py-0 group-hover:border-global-bg/40 group-hover:text-global-bg/80",
							status === "active" ? "border-border text-text-tertiary" : "border-border-light text-text-tertiary/60"
						]}
						style="font-size: 10px; letter-spacing: 0.05em;"
					>{status === "active" ? "ACTIVE" : "ARCHIVED"}</span>
				)}
			</div>
			<div class="mt-1 text-text-secondary group-hover:text-global-bg/80" style="font-size: var(--text-micro);">{description}</div>
		</div>
		<span class="text-text-tertiary transition-transform group-hover:translate-x-1 group-hover:text-global-bg" aria-hidden="true">→</span>
	</div>
</a>
